$root/bin/mars -o 8393728 -M $root/.jc-sol.map $3 $root/lib/haruka-runtime.sol $1/trailer.sol
$root/bin/orgasm -m $root/.jc-asm.map $root/.jc-sol.map $1/start.asm $1/runtime.asm $1/juicer.asm $root/.jc-prefix
$root/bin/pad $root/.jc-prefix 1024 1024
$root/bin/mars -o 8393728 $3 $root/lib/haruka-runtime.sol $1/trailer.sol $root/.jc-asm.map $root/.jc-code
$root/bin/concat $root/.jc-raw $root/.jc-prefix $root/.jc-code
$root/bin/jews c $root/.jc-raw $2
