echo [ Building FruityOS boot seeds for $1 ]
mkdir out
mkdir out/$1
cd src/fdseed
build.psh $1
cd ../hdseed
build.psh $1
cd ../uefiseed
build.psh $1
cd ../..
copy src/fdseed/out/$1/fdseed.bin out/$1/fdseed.bin
copy src/hdseed/out/$1/hdseed.bin out/$1/hdseed.bin
copy src/uefiseed/out/$1/uefiseed-prefix.bin out/$1/uefiseed-prefix.bin
echo Seed build complete.
