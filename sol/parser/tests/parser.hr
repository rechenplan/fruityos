record Counter value

sub parser_check(condition, code)
  if condition == 0 then return code end
  return 0
end

sub main(argc, argv)
  local first:SolSource = new SolSource, second:SolSource = new SolSource
  local parser:SolParser, item:SolItem, result = 0, counter:Counter = new Counter, visit

  first.name = "first.sol"
  first.text = "sol 1\norg 0x1000\nglobal Start\nextern ext\nStart:\nenter 2\nmov a, -42\nadd b, a, 0b1010\nld c, [fp + slot]\nst [sp - 8], c\nbz c, done\ndb \"A\\n\", 0xff, ext\n"
  first.next = second
  second.name = "second.sol"
  second.text = "done: ret 1\n"

  parser = sol_parser_new(first)

  item = sol_next(parser)
  result = parser_check(item.kind == 2, 1) if result == 0 then result = parser_check(item.number == 1, 2) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 3, 3) end
  if result == 0 then result = parser_check(item.number == 4096, 4) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 5, 5) end
  if result == 0 then result = parser_check(sol_text_equal(item.name, item.name_length, "Start"), 6) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 6, 7) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 4, 8) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 29, 9) end
  if result == 0 then result = parser_check(item.first.value.number == 2, 10) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 1, 11) end
  if result == 0 then result = parser_check(item.second.value.number == -42, 12) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 2, 13) end
  if result == 0 then result = parser_check(item.third.value.number == 10, 14) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 18, 15) end
  if result == 0 then result = parser_check(item.second.kind == 2, 16) end
  if result == 0 then result = parser_check(item.second.base.register == 6, 17) end
  if result == 0 then result = parser_check(item.second.offset.kind == 3, 18) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 20, 19) end
  if result == 0 then result = parser_check(item.first.offset.number == -8, 20) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 22, 21) end
  if result == 0 then result = parser_check(item.second.value.kind == 3, 22) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 8, 23) end
  if result == 0 then result = parser_check(item.width == 1, 24) end
  if result == 0 then result = parser_check(item.first.value.kind == 4, 25) end
  if result == 0 then result = parser_check(item.more, 26) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.first.value.number == 255, 27) end
  if result == 0 then result = parser_check(item.more, 28) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.first.value.kind == 3, 29) end
  if result == 0 then result = parser_check(item.more == 0, 30) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 4, 31) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.operation == 26, 33) end

  item = sol_next(parser)
  if result == 0 then result = parser_check(item.kind == 0, 34) end

  if result == 0 then
    sol_reset(parser)
    visit = fn current:SolItem do
      counter.value = counter.value + 1
      return 0
    end
    if sol_each(parser, visit) == 0 then result = 35 end
    if (result == 0) && (counter.value != 16) then result = 36 end
  end

  return result
end
