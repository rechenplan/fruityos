sub SOL_TOKEN_LBRACKET() return 8 end
sub SOL_TOKEN_RBRACKET() return 9 end
sub SOL_TOKEN_PLUS() return 10 end
sub SOL_TOKEN_MINUS() return 11 end
sub SOL_TOKEN_WORD_NUMBER() return 12 end

sub SOL_TERM_NONE() return 0 end
