record SolSource name, text, next:SolSource
record SolTerm kind, register, number, text, length
record SolOperand kind, value:SolTerm, base:SolTerm, offset:SolTerm
record SolItem kind, operation, width, number, name, name_length, message,
       source_name, line, column, operand_count,
       first:SolOperand, second:SolOperand, third:SolOperand, more
record SolParser first:SolSource, source:SolSource,
       position, line, column,
       token_kind, token_start, token_length, token_number,
       token_source_name, token_line, token_column,
       item:SolItem, failed, error_text,
       saw_version, pending_data, pending_width,
       pending_index, pending_source_name, pending_line, pending_column

sub SOL_TOKEN_EOF() return 0 end
sub SOL_TOKEN_ERROR() return 1 end
sub SOL_TOKEN_ID() return 2 end
sub SOL_TOKEN_NUMBER() return 3 end
sub SOL_TOKEN_STRING() return 4 end
sub SOL_TOKEN_NEWLINE() return 5 end
sub SOL_TOKEN_COMMA() return 6 end
