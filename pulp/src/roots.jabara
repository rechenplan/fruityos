; Assembly-visible roots for optional Jabara dead-function elimination.
sub __jabara_roots()
  kmain()
  kputn()
  kputs()
  sys_brk()
  sys_chdir()
  sys_close()
  sys_creat()
  sys_dup2()
  sys_exec()
  sys_exit()
  sys_fgetch()
  sys_fork()
  sys_fputch()
  sys_getch()
  sys_getcwd()
  sys_getdents64()
  sys_keyboard()
  sys_mkdir()
  sys_mmap()
  sys_open()
  sys_putch()
  sys_read()
  sys_rename()
  sys_rmdir()
  sys_seek()
  sys_stub()
  sys_unlink()
  sys_waitpid()
  sys_write()
end
