sub kmain(initrd)
	local fd

	kputs("Booting...")
	gdt_init()
	page_init()
	tss_init()
	idt_init()
	heap_init()
	global_init()
	kunpack(initrd)
	idt_sti()
	kcls()

	; fd = sys_open("/init.psh", 0)
	; if fd != 0 then
	;	pish_main(fd)
	; end
	; sys_close(fd)

	sys_exec("/bin/pish.fap", 0, 0)
	user_jmp()
end
