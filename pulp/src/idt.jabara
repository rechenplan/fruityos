; idt table functions

sub idt_getSize()
	return 4096
end

sub idt_getIdtrSize()
	return 10
end

sub idt_init()
	pic_init()
	_idt = 61440 ; 0xf000
	idt_populate(_idt)

	_idtr = 1280 ; 0x500
	byte [_idtr] = 255
	byte [_idtr + 1] = 15
	[_idtr + 2] = _idt
	idt_load(_idtr)
end

sub idt_cleanup()
	idt_cli()
	_idt = 0
	_idtr = 0
end
